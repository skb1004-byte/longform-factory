# LongForm Factory AI-MCP Service 환경 설정

# ==================== API 키 ====================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini API
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-pro

# OpenAI API (OpenAI, Cerebras, OpenRouter, ArliAI 호환)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4

# LongForm Factory API 키 (X-LF-API-Key 헤더)
LF_API_KEY=your-lf-api-key-here

# ==================== RALF 재시도 설정 ====================

# 최대 재시도 횟수 (기본: 3)
RALF_MAX_RETRIES=3

# 기본 재시도 대기 시간 (초, 기본: 1.0)
# 실제 대기 = base_delay * (2 ^ attempt)
RALF_BASE_DELAY=1.0

# ==================== 프로바이더별 추가 설정 ====================

# Cerebras API (OpenAI 호환)
# Base URL: https://api.cerebras.ai/v1
# 모델 예: llama-3.1-70b

# OpenRouter API (OpenAI 호환)
# Base URL: https://openrouter.ai/api/v1
# 모델 예: meta-llama/llama-3.1-70b-instruct:free

# ArliAI API (OpenAI 호환)
# Base URL: https://api.arliai.com/v1
# 모델 예: claude-3-5-sonnet
