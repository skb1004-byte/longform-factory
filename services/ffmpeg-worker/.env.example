# FFmpeg Worker - 환경 변수 설정
# .env 파일을 복사하여 실제 값으로 수정하세요

# API 키
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
LF_API_KEY=your_longform_factory_api_key_here

# 타임존
TZ=Asia/Seoul

# Python 버퍼 설정 (Docker 로깅용)
PYTHONUNBUFFERED=1

# 서버 설정
HOST=0.0.0.0
PORT=8002
WORKERS=2

# 로깅 레벨
LOG_LEVEL=INFO

# 작업 타임아웃 (초)
JOB_TIMEOUT=600

# 다운로드 타임아웃 (초)
DOWNLOAD_TIMEOUT=60

# 배경음악 기본 볼륨 (0.0 ~ 1.0)
DEFAULT_BGM_VOLUME=0.3

# 숏폼 최대 길이 (초)
SHORTS_MAX_DURATION=60

# 썸네일 추출 위치 (초)
THUMBNAIL_TIMESTAMP=3
