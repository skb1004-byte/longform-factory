{
  "name": "🎬 롱폼 자동화 파이프라인 v2",
  "nodes": [
    {
      "parameters": {},
      "id": "trigger-manual",
      "name": "수동 실행",
      "type": "n8n-nodes-base.manualTrigger",
      "position": [240, 400]
    },
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 9 * * *" }] }
      },
      "id": "trigger-schedule",
      "name": "매일 09시 자동 실행",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 560]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "1", "name": "topic", "value": "={{ $json.topic || '2026년 AI 기술 트렌드 완전 분석' }}", "type": "string" },
            { "id": "2", "name": "language", "value": "ko", "type": "string" },
            { "id": "3", "name": "target_duration", "value": 600, "type": "number" },
            { "id": "4", "name": "style", "value": "educational_engaging", "type": "string" },
            { "id": "5", "name": "job_id", "value": "={{ 'lf_' + $now.toFormat('yyyyMMdd_HHmmss') }}", "type": "string" }
          ]
        }
      },
      "id": "set-params",
      "name": "파라미터 설정",
      "type": "n8n-nodes-base.set",
      "position": [460, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.MCP_URL }}/generate/script",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "topic", "value": "={{ $json.topic }}" },
            { "name": "language", "value": "={{ $json.language }}" },
            { "name": "target_duration", "value": "={{ $json.target_duration }}" },
            { "name": "style", "value": "={{ $json.style }}" },
            { "name": "model", "value": "anthropic" },
            { "name": "format", "value": "structured_scenes" }
          ]
        }
      },
      "id": "generate-script",
      "name": "📝 스크립트 생성 (Claude)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [680, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.TTS_URL }}/synthesize",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "text", "value": "={{ $json.script_text }}" },
            { "name": "voice_id", "value": "21m00Tcm4TlvDq8ikWAM" },
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" },
            { "name": "output_format", "value": "mp3_44100_128" }
          ]
        }
      },
      "id": "tts-generate",
      "name": "🎙️ TTS 음성 생성 (ElevenLabs)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 360]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FFMPEG_URL }}/assets/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "scenes", "value": "={{ $json.scenes }}" },
            { "name": "sources", "value": "pexels,pixabay" },
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" }
          ]
        }
      },
      "id": "search-assets",
      "name": "🖼️ 영상 소스 검색 (Pexels+Pixabay)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 600]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FFMPEG_URL }}/video/create",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" },
            { "name": "mode", "value": "longform" },
            { "name": "resolution", "value": "1920x1080" },
            { "name": "fps", "value": 30 },
            { "name": "add_subtitles", "value": true },
            { "name": "add_bgm", "value": true },
            { "name": "bgm_volume", "value": 0.08 },
            { "name": "generate_thumbnail", "value": true },
            { "name": "generate_shorts", "value": true }
          ]
        }
      },
      "id": "create-video",
      "name": "🎬 롱폼 영상 조립 (FFmpeg)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1120, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.UPLOADER_URL }}/upload/youtube",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" },
            { "name": "type", "value": "longform" },
            { "name": "title", "value": "={{ $('📝 스크립트 생성 (Claude)').item.json.title }}" },
            { "name": "description", "value": "={{ $('📝 스크립트 생성 (Claude)').item.json.description }}" },
            { "name": "tags", "value": "={{ $('📝 스크립트 생성 (Claude)').item.json.tags }}" },
            { "name": "privacy", "value": "public" }
          ]
        }
      },
      "id": "upload-youtube",
      "name": "📺 YouTube 업로드",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1340, 360]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.UPLOADER_URL }}/upload/youtube",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" },
            { "name": "type", "value": "shorts" },
            { "name": "title", "value": "={{ $('📝 스크립트 생성 (Claude)').item.json.shorts_title + ' #Shorts' }}" },
            { "name": "privacy", "value": "public" }
          ]
        }
      },
      "id": "upload-shorts",
      "name": "📱 YouTube Shorts 업로드",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1340, 600]
    }
  ],
  "connections": {
    "수동 실행": { "main": [[{ "node": "파라미터 설정", "type": "main", "index": 0 }]] },
    "매일 09시 자동 실행": { "main": [[{ "node": "파라미터 설정", "type": "main", "index": 0 }]] },
    "파라미터 설정": { "main": [[{ "node": "📝 스크립트 생성 (Claude)", "type": "main", "index": 0 }]] },
    "📝 스크립트 생성 (Claude)": {
      "main": [[
        { "node": "🎙️ TTS 음성 생성 (ElevenLabs)", "type": "main", "index": 0 },
        { "node": "🖼️ 영상 소스 검색 (Pexels+Pixabay)", "type": "main", "index": 0 }
      ]]
    },
    "🎙️ TTS 음성 생성 (ElevenLabs)": { "main": [[{ "node": "🎬 롱폼 영상 조립 (FFmpeg)", "type": "main", "index": 0 }]] },
    "🖼️ 영상 소스 검색 (Pexels+Pixabay)": { "main": [[{ "node": "🎬 롱폼 영상 조립 (FFmpeg)", "type": "main", "index": 0 }]] },
    "🎬 롱폼 영상 조립 (FFmpeg)": {
      "main": [[
        { "node": "📺 YouTube 업로드", "type": "main", "index": 0 },
        { "node": "📱 YouTube Shorts 업로드", "type": "main", "index": 0 }
      ]]
    }
  },
  "settings": { "executionOrder": "v1", "timezone": "Asia/Seoul" },
  "tags": [{ "name": "longform" }, { "name": "v2" }]
}
