{
  "name": "📱 숏폼 자동화 파이프라인 v2",
  "nodes": [
    {
      "parameters": {},
      "id": "trigger-manual-s",
      "name": "수동 실행",
      "type": "n8n-nodes-base.manualTrigger",
      "position": [240, 400]
    },
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 18 * * *" }] }
      },
      "id": "trigger-schedule-s",
      "name": "매일 18시 자동 실행",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 560]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "1", "name": "topic", "value": "={{ $json.topic || '오늘의 AI 꿀팁 3가지' }}", "type": "string" },
            { "id": "2", "name": "language", "value": "ko", "type": "string" },
            { "id": "3", "name": "target_duration", "value": 60, "type": "number" },
            { "id": "4", "name": "job_id", "value": "={{ 'sf_' + $now.toFormat('yyyyMMdd_HHmmss') }}", "type": "string" }
          ]
        }
      },
      "id": "set-params-s",
      "name": "파라미터 설정",
      "type": "n8n-nodes-base.set",
      "position": [460, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.MCP_URL }}/generate/script",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "topic", "value": "={{ $json.topic }}" },
            { "name": "language", "value": "={{ $json.language }}" },
            { "name": "target_duration", "value": 60 },
            { "name": "style", "value": "shorts_viral" },
            { "name": "model", "value": "anthropic" },
            { "name": "format", "value": "shorts_hook_content_cta" }
          ]
        }
      },
      "id": "generate-script-s",
      "name": "📝 숏폼 스크립트 생성 (Claude Haiku)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [680, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.TTS_URL }}/synthesize",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "text", "value": "={{ $json.script_text }}" },
            { "name": "voice_id", "value": "21m00Tcm4TlvDq8ikWAM" },
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" },
            { "name": "speed", "value": 1.1 }
          ]
        }
      },
      "id": "tts-s",
      "name": "🎙️ TTS 생성",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 360]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FFMPEG_URL }}/assets/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "scenes", "value": "={{ $json.scenes }}" },
            { "name": "sources", "value": "pexels,pixabay" },
            { "name": "orientation", "value": "portrait" },
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" }
          ]
        }
      },
      "id": "search-assets-s",
      "name": "🖼️ 세로 영상 소스 검색",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 600]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FFMPEG_URL }}/video/create",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" },
            { "name": "mode", "value": "shorts" },
            { "name": "resolution", "value": "1080x1920" },
            { "name": "fps", "value": 30 },
            { "name": "add_captions", "value": true },
            { "name": "caption_style", "value": "tiktok_bold" },
            { "name": "add_bgm", "value": true },
            { "name": "bgm_volume", "value": 0.05 },
            { "name": "ken_burns_effect", "value": true }
          ]
        }
      },
      "id": "create-video-s",
      "name": "📱 숏폼 영상 조립 (9:16)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1120, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.UPLOADER_URL }}/upload/youtube",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $env.LF_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "job_id", "value": "={{ $('파라미터 설정').item.json.job_id }}" },
            { "name": "type", "value": "shorts" },
            { "name": "title", "value": "={{ $('📝 숏폼 스크립트 생성 (Claude Haiku)').item.json.title + ' #Shorts' }}" },
            { "name": "privacy", "value": "public" }
          ]
        }
      },
      "id": "upload-shorts-s",
      "name": "📤 YouTube Shorts 업로드",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1340, 480]
    }
  ],
  "connections": {
    "수동 실행": { "main": [[{ "node": "파라미터 설정", "type": "main", "index": 0 }]] },
    "매일 18시 자동 실행": { "main": [[{ "node": "파라미터 설정", "type": "main", "index": 0 }]] },
    "파라미터 설정": { "main": [[{ "node": "📝 숏폼 스크립트 생성 (Claude Haiku)", "type": "main", "index": 0 }]] },
    "📝 숏폼 스크립트 생성 (Claude Haiku)": {
      "main": [[
        { "node": "🎙️ TTS 생성", "type": "main", "index": 0 },
        { "node": "🖼️ 세로 영상 소스 검색", "type": "main", "index": 0 }
      ]]
    },
    "🎙️ TTS 생성": { "main": [[{ "node": "📱 숏폼 영상 조립 (9:16)", "type": "main", "index": 0 }]] },
    "🖼️ 세로 영상 소스 검색": { "main": [[{ "node": "📱 숏폼 영상 조립 (9:16)", "type": "main", "index": 0 }]] },
    "📱 숏폼 영상 조립 (9:16)": { "main": [[{ "node": "📤 YouTube Shorts 업로드", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1", "timezone": "Asia/Seoul" },
  "tags": [{ "name": "shortform" }, { "name": "v2" }]
}
